<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Android 11+ 카카오톡 앱 쿼리를 위한 설정 -->
    <queries>
        <package android:name="com.kakao.talk" />
    </queries>

    <application
        android:name=".StadyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StadyApp"
        tools:targetApi="31">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.StadyApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.StadyApp"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode" />

        <!-- 카카오 계정(ID/PW) 로그인 리다이렉트 핸들러.
             카카오톡 미설치 기기(예: 갤럭시탭)는 loginWithKakaoAccount() 경로를 타고,
             웹 로그인 후 커스텀탭(브라우저)이 kakao{앱키}://oauth 로 앱을 다시 깨운다.
             이 인텐트필터는 반드시 SDK가 제공하는 AuthCodeHandlerActivity 에 붙여야
             코드가 SDK 로 전달되며, 외부(브라우저)에서 띄우므로 exported=true 여야 한다.
             (이전엔 MainActivity 에 exported=false 로 붙어 있어 탭에서 로그인이 실패했다.) -->
        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="oauth"
                    android:scheme="kakaodf2af4aa578aaca7fcd5afca3ac8861b" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.kakao.sdk.AppKey"
            android:value="df2af4aa578aaca7fcd5afca3ac8861b" />

    </application>

</manifest>